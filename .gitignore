.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache

# ── VS Code ───────────────────────────────────────────────────────
.vscode/

# ── Cấu hình nhạy cảm (QUAN TRỌNG - KHÔNG push lên Git) ──────────
